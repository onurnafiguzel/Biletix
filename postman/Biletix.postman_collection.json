{
  "info": {
    "name": "Biletix",
    "_postman_id": "biletix-collection-002",
    "description": "Biletix modüler monolit — tek host (port 8080) altında Events / Bookings / Search endpoint'leri.\n\nÇalıştırma sırası:\n1. Health.\n2. Events → Seed Event (eventId değişkene yazılır).\n3. Events → Get Event Details (ticketId, ticketId2 yazılır).\n4. Bookings → Create Booking.\n5. Search (CDC pipeline çalışıyorsa) → arama.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "apiUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "kafkaConnectUrl", "value": "http://localhost:8085", "type": "string" },
    { "key": "eventId", "value": "", "type": "string" },
    { "key": "ticketId", "value": "", "type": "string" },
    { "key": "ticketId2", "value": "", "type": "string" },
    { "key": "userId", "value": "11111111-1111-1111-1111-111111111111", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{apiUrl}}/health", "host": ["{{apiUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Seed Event (100 tickets)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.id) { pm.collectionVariables.set('eventId', body.id); console.log('eventId =', body.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tarkan İstanbul\",\n  \"startsAt\": \"2026-09-15T20:00:00Z\",\n  \"venueName\": \"Vodafone Park\",\n  \"city\": \"İstanbul\",\n  \"performerName\": \"Tarkan\",\n  \"ticketCount\": 100,\n  \"price\": 1500\n}"
            },
            "url": { "raw": "{{apiUrl}}/events/seed", "host": ["{{apiUrl}}"], "path": ["events", "seed"] }
          }
        },
        {
          "name": "List Upcoming Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{apiUrl}}/events?upcoming=true&pageNumber=1&pageSize=20",
              "host": ["{{apiUrl}}"],
              "path": ["events"],
              "query": [
                { "key": "upcoming", "value": "true" },
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Event Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const av = (body.tickets || []).filter(t => t.status === 'Available');",
                  "if (av.length > 0) pm.collectionVariables.set('ticketId', av[0].id);",
                  "if (av.length > 1) pm.collectionVariables.set('ticketId2', av[1].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{apiUrl}}/events/{{eventId}}", "host": ["{{apiUrl}}"], "path": ["events", "{{eventId}}"] }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking (single ticket)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketIds\": [\"{{ticketId}}\"],\n  \"userId\": \"{{userId}}\",\n  \"paymentDetails\": { \"cardNumberMasked\": \"**** **** **** 1234\", \"holder\": \"Test User\" }\n}"
            },
            "url": { "raw": "{{apiUrl}}/bookings/{{eventId}}", "host": ["{{apiUrl}}"], "path": ["bookings", "{{eventId}}"] }
          }
        },
        {
          "name": "Create Booking (multiple tickets)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketIds\": [\"{{ticketId}}\", \"{{ticketId2}}\"],\n  \"userId\": \"{{userId}}\",\n  \"paymentDetails\": { \"cardNumberMasked\": \"**** **** **** 1234\", \"holder\": \"Test User\" }\n}"
            },
            "url": { "raw": "{{apiUrl}}/bookings/{{eventId}}", "host": ["{{apiUrl}}"], "path": ["bookings", "{{eventId}}"] }
          }
        },
        {
          "name": "Create Booking — Conflict (same ticket twice)",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [ "pm.test('Expect 409', () => pm.expect(pm.response.code).to.eql(409));" ] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketIds\": [\"{{ticketId}}\"],\n  \"userId\": \"22222222-2222-2222-2222-222222222222\",\n  \"paymentDetails\": { \"cardNumberMasked\": \"**** **** **** 9999\", \"holder\": \"Other\" }\n}"
            },
            "url": { "raw": "{{apiUrl}}/bookings/{{eventId}}", "host": ["{{apiUrl}}"], "path": ["bookings", "{{eventId}}"] }
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search by keyword",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{apiUrl}}/search?keyword=tarkan&pageSize=20&pageNumber=1",
              "host": ["{{apiUrl}}"],
              "path": ["search"],
              "query": [
                { "key": "keyword", "value": "tarkan" },
                { "key": "pageSize", "value": "20" },
                { "key": "pageNumber", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Search by date range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{apiUrl}}/search?startDate=2026-01-01T00:00:00Z&endDate=2026-12-31T23:59:59Z",
              "host": ["{{apiUrl}}"],
              "path": ["search"],
              "query": [
                { "key": "startDate", "value": "2026-01-01T00:00:00Z" },
                { "key": "endDate", "value": "2026-12-31T23:59:59Z" }
              ]
            }
          }
        },
        {
          "name": "Search (all)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{apiUrl}}/search", "host": ["{{apiUrl}}"], "path": ["search"] }
          }
        }
      ]
    },
    {
      "name": "Kafka Connect (CDC ops)",
      "item": [
        {
          "name": "List Connectors",
          "request": {
            "method": "GET",
            "url": { "raw": "{{kafkaConnectUrl}}/connectors", "host": ["{{kafkaConnectUrl}}"], "path": ["connectors"] }
          }
        },
        {
          "name": "Connector Status — Source",
          "request": {
            "method": "GET",
            "url": { "raw": "{{kafkaConnectUrl}}/connectors/biletix-source/status", "host": ["{{kafkaConnectUrl}}"], "path": ["connectors", "biletix-source", "status"] }
          }
        },
        {
          "name": "Connector Status — ES Sink",
          "request": {
            "method": "GET",
            "url": { "raw": "{{kafkaConnectUrl}}/connectors/biletix-es-sink/status", "host": ["{{kafkaConnectUrl}}"], "path": ["connectors", "biletix-es-sink", "status"] }
          }
        }
      ]
    }
  ]
}
